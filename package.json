{
  "name": "@inixiative/permissions",
  "version": "0.3.2",
  "description": "Generic rebac/abac/rbac core — a permix wrapper + relationship-walking check engine; relation resolution is injected (built from prisma-map in the inixiative stack)",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "bun run typecheck && bun run lint && bun run test",
    "prepare": "lefthook install",
    "prepublishOnly": "bun run check && bun run build"
  },
  "keywords": [
    "permissions",
    "authorization",
    "rebac",
    "abac",
    "rbac",
    "permix",
    "json-rules",
    "typescript"
  ],
  "author": "Aron Greenspan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inixiative/permissions.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@inixiative/config": "^0.3.1",
    "@types/bun": "1.3.14",
    "@types/lodash-es": "^4.17.12",
    "lefthook": "2.1.9",
    "permix": "^3.6.0",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "typescript": "^5.0.0",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "dependencies": {
    "@inixiative/json-rules": "^2.14.0",
    "lodash-es": "^4.17.21"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./actionRuleSchema": {
      "types": "./dist/actionRuleSchema.d.ts",
      "import": "./dist/actionRuleSchema.js",
      "require": "./dist/actionRuleSchema.cjs"
    }
  },
  "packageManager": "bun@1.3.14"
}
